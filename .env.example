# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_IMAGE_BUCKET=newsroom-images

# Admin auth
# Add one or more admin email addresses separated by commas. These users must exist in Supabase Auth.
ADMIN_EMAILS=you@example.com

# AI brain provider: openai, gemini, or mock
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash

# Image generation provider: placeholder or openai
# placeholder creates an editorial SVG card so the full workflow works before image keys are configured.
IMAGE_PROVIDER=placeholder
OPENAI_IMAGE_MODEL=gpt-image-1

# Telegram approval
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=change-this-secret
PUBLIC_BASE_URL=https://your-netlify-site.netlify.app

# App
NEXT_PUBLIC_APP_NAME=Newsroom Lab
NEXT_PUBLIC_DEFAULT_JOURNALIST_ID=anika-patel
